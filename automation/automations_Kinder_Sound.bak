
- alias: EisbärKleinRot
  initial_state: 'on'
  trigger:
    platform: state
    entity_id:  sensor.kids_sound
    to: '351050810'
  action:
  - service: media_player.select_source
    data_template:
      entity_id: media_player.spielzimmer
      source: EisbarKleinRot
  id: c145ghz7H0cc48asb0b1d87c28edsefg

